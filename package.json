{
  "name": "transportabr-server",
  "version": "0.1.0",
  "description": "Backend NestJS + Prisma (PostgreSQL) para o TransportaBR",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "dotenv -e .env -o -- nest start",
    "start:dev": "dotenv -e .env -o -- nest start --watch",
    "start:prod": "dotenv -e .env -o -- node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env -o -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env -o -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env -o -- prisma studio",
    "import:csv": "dotenv -e .env -o -- node src/migration/import-csv.mjs",
    "token": "dotenv -e .env -o -- node src/auth/mint-token.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^7.0.0",
    "google-auth-library": "^10.9.0",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
