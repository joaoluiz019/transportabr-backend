# PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:5432/transportabr?sslmode=require"

# Porta da API
PORT=3000

# CORS: em produção, defina a(s) origem(ns) do frontend (separadas por vírgula).
# Vazio = libera todas as origens (apenas para desenvolvimento).
CORS_ORIGIN=""

# JWT
JWT_SECRET="troque-este-segredo"
JWT_EXPIRES_IN="7d"

# URL do frontend (links de e-mail, ex.: redefinição de senha)
APP_URL="http://localhost:5173"

# Login social (cliente envia o token do provedor; backend valida e emite JWT)
GOOGLE_CLIENT_ID=""
APPLE_CLIENT_ID=""

# SMTP (envio de e-mail). Vazio = apenas loga no console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="TransportaBR <no-reply@exemplo.com>"
